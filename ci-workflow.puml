@startuml
title CI Workflow — fake_info_frontend

start

group Setup {
  :Checkout code;
  :Start backend stack;
}

group Frontend {
  :Install deps & lint (ESLint);
  if (Lint passes?) then (yes)
  else (no)
    :Pipeline fails;
  endif
}

group E2E Tests {
  :Run Playwright tests;
  if (Tests pass?) then (yes)
  else (no)
    :Pipeline fails;
  endif
}

group Publish (always runs) {
  :Tear down backend stack;
  :Upload & deploy report\nto GitHub Pages;
}

stop
@enduml
